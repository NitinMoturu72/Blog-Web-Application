<%- include("partials/header.ejs") %>

    <div class="home-content">

        <h1>Welcome to Blogopia</h1>

        <% if(locals.posts) { %>
            <ol type="1">
                <% posts.forEach((post) => { %>
                    <li class="py-1">
                        <form action="/viewPost" method="POST">
                            <input type="hidden" name="blogId" value="<%= post.id %>">
                            <input type="submit" value="<%= post.title %>">
                        </form>
                    </li>
                <% }) %>
            </ol>
        <% } %>
    </div>

<%- include("partials/footer.ejs") %>

